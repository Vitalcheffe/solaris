# ============================================
# SOLARIS - Environment Variables
# ============================================
# Copiez ce fichier en .env et remplissez vos clés
# cp .env.example .env
# ⚠️ NE JAMAIS COMMIT LE FICHIER .env !

# ---- Solana RPC ----
# Option 1: RPC public (gratuit, limité)
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_WS_URL=wss://api.mainnet-beta.solana.com

# Option 2: Helius (gratuit, recommandé)
# Créer un compte sur https://dev.helius.xyz
HELIUS_API_KEY=

# ---- Données de marché ----
# Birdeye API (gratuit pour le basic)
# Créer sur https://birdeye.so → Settings → API
BIRDEYE_API_KEY=

# ---- Wallet (UNIQUEMENT pour le mode LIVE) ----
# ⚠️ NE REMPLIR QUE SI VOUS TRADEZ EN RÉEL
# Votre clé publique Solana
SOLANA_PUBLIC_KEY=
# Votre clé privée en Base58 (GARDEZ-LA SECURISÉE)
SOLANA_PRIVATE_KEY=

# ---- Alertes Telegram (optionnel) ----
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
